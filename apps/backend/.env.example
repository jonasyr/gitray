# =============================================================================
# GITRAY BACKEND CONFIGURATION - EXAMPLE
# =============================================================================
#
# 🚀 SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Adjust values below for your local environment
# 3. Run: node test-config-dynamic.mjs (to verify all variables work)
#
# 📝 NOTES:
# - This file shows all required environment variables with safe defaults
# - Modify .env (not this file) for your actual configuration
# - .env is gitignored to prevent accidental commits of local settings
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CONNECT_TIMEOUT=10000
REDIS_LAZY_CONNECT=true
CACHE_REDIS_PREFIX=gitray:cache:

# -----------------------------------------------------------------------------
# CACHE SYSTEM (HybridLRUCache)
# -----------------------------------------------------------------------------
# Main Cache Settings
CACHE_ENABLE_REDIS=true
CACHE_ENABLE_DISK=true
CACHE_MEMORY_LIMIT_GB=2
CACHE_MAX_ENTRIES=5000
CACHE_ONDISK_PATH=./cache
CACHE_LOCK_TIMEOUT_MS=30000

# Cache Performance Tuning
CACHE_DISK_SYNC_INTERVAL_MS=5000
CACHE_MEMORY_CHECK_INTERVAL_MS=1000

# Cache TTL Settings (seconds)
CACHE_RAW_COMMITS_TTL_SECONDS=3600
CACHE_FILTERED_COMMITS_TTL_SECONDS=1800
CACHE_AGGREGATED_DATA_TTL_SECONDS=900
CACHE_REPOSITORY_INFO_TTL_SECONDS=7200

# Cache Strategy
CACHE_HIERARCHICAL_ENABLED=true
CACHE_MEMORY_PRESSURE_THRESHOLD=80
CACHE_EMERGENCY_EVICTION_PERCENT=30
CACHE_LARGE_VALUE_BYPASS_PERCENT=10

# -----------------------------------------------------------------------------
# REPOSITORY COORDINATION
# -----------------------------------------------------------------------------
REPO_CACHE_ENABLED=true
REPO_CACHE_MAX_REPOSITORIES=15
REPO_CACHE_MAX_AGE_HOURS=4
REPO_CACHE_MEMORY_LIMIT_GB=1
REPO_CACHE_DISK_LIMIT_GB=5
REPO_CACHE_BASE_PATH=./shared-repos
REPO_CACHE_CLEANUP_INTERVAL_MS=300000
REPO_CACHE_AGGRESSIVE_EVICTION=true

# Operation Coordination
REPO_OPERATION_COORDINATION_ENABLED=true
REPO_OPERATION_TIMEOUT_MS=600000
REPO_OPERATION_COALESCING_ENABLED=true
REPO_MAX_CONCURRENT_OPS=3
REPO_OPERATION_MAX_QUEUE_SIZE=10

# -----------------------------------------------------------------------------
# STREAMING (Large Repositories)
# -----------------------------------------------------------------------------
STREAMING_ENABLED=true
STREAMING_COMMIT_THRESHOLD=25000
STREAMING_BATCH_SIZE=1000

# -----------------------------------------------------------------------------
# GIT OPERATIONS
# -----------------------------------------------------------------------------
GIT_MAX_CONCURRENT_PROCESSES=6
GIT_CLONE_DEPTH=50

# -----------------------------------------------------------------------------
# LOCK MANAGER
# -----------------------------------------------------------------------------
LOCK_DIR=./locks
LOCK_CLEANUP_INTERVAL_MS=300000
LOCK_STALE_AGE_MS=600000

# -----------------------------------------------------------------------------
# LOGGING & DEBUGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# File Logging Configuration
LOG_TO_FILE=true
LOG_DIR=./logs
LOG_ENABLE_CONSOLE=true
LOG_CONSOLE_LEVEL=info
LOG_ENABLE_COMBINED_FILE=true
LOG_ENABLE_ERROR_FILE=true
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=10
LOG_DATE_PATTERN=YYYY-MM-DD

# Debug Flags
DEBUG_CACHE_LOGGING=false
DEBUG_LOCK_LOGGING=false
DEBUG_REPO_OPERATIONS=false
ENABLE_METRICS=true

# -----------------------------------------------------------------------------
# SYSTEM
# -----------------------------------------------------------------------------
GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# MEMORY MANAGEMENT (CRITICAL PRODUCTION SAFETY)
# -----------------------------------------------------------------------------
# System Memory Thresholds (percentages)
MEMORY_WARNING_THRESHOLD=75
MEMORY_CRITICAL_THRESHOLD=85
MEMORY_EMERGENCY_THRESHOLD=95

# Process Memory Thresholds (percentages of system memory)
MEMORY_PROCESS_WARNING_THRESHOLD=50
MEMORY_PROCESS_CRITICAL_THRESHOLD=70

# Circuit Breaker Configuration
MEMORY_CIRCUIT_BREAKER=true
MEMORY_REQUEST_THROTTLING=true
MEMORY_EMERGENCY_EVICTION=true

# Monitoring Configuration
MEMORY_CHECK_INTERVAL_MS=5000
MEMORY_ALERT_COOLDOWN_MS=60000