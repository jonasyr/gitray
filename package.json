{
  "name": "gitray",
  "version": "1.0.0",
  "description": "Git visualization tool",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "app": "./start.sh",
    "start": "./start.sh dev",
    "quick": "./start.sh quick",
    "env:status": "./start.sh status",
    "env:stop": "./start.sh stop",
    "env:clean": "./start.sh clean",
    "dev": "pnpm run build:shared-types && pnpm -r run dev",
    "dev:frontend": "pnpm --filter frontend run dev",
    "dev:backend": "pnpm --filter backend run dev",
    "build": "pnpm run build:shared-types && pnpm run build:apps",
    "build:shared-types": "pnpm --filter @gitray/shared-types build",
    "build:apps": "pnpm --filter backend build && pnpm --filter frontend build",
    "clean": "pnpm run clean:dist && pnpm run clean:cache && pnpm run clean:node_modules",
    "clean:dist": "rimraf packages/*/dist apps/*/dist && find . -name '*.tsbuildinfo' -not -path './node_modules/*' -delete 2>/dev/null || true && rimraf coverage apps/*/coverage packages/*/coverage",
    "clean:node_modules": "find . -type d -name 'node_modules' -exec rm -rf {} + 2>/dev/null || true && rimraf pnpm-lock.yaml",
    "clean:cache": "rimraf .vite apps/*/.vite .eslintcache apps/*/.eslintcache .nyc_output apps/*/.nyc_output .tmp apps/*/.tmp packages/*/.tmp && rimraf **/.turbo **/dist-ssr",
    "clean:all": "pnpm run clean && rimraf **/.DS_Store **/*.log",
    "rebuild": "pnpm run clean && pnpm install && pnpm build",
    "test": "jest --config=jest.config.cjs",
    "test:frontend": "cd apps/frontend && jest",
    "test:backend": "cd apps/backend && jest",
    "test:watch": "jest --config=jest.config.cjs --watchAll",
    "test:watch:changed": "jest --config=jest.config.cjs --watch",
    "test:coverage": "jest --config=jest.config.cjs --coverage",
    "lint": "eslint . --ext .js,.ts,.jsx,.tsx,.cjs,.mjs",
    "lint:md": "markdownlint-cli2",
    "lint:fix": "eslint . --ext .js,.ts,.jsx,.tsx,.cjs,.mjs --fix",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{md,markdown}": [
      "markdownlint-cli2 --fix"
    ],
    "**/*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.8.1",
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/jest": "^29.5.14",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-transform-stub": "^2.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "lint-staged": "^15.5.2",
    "markdownlint-cli2": "^0.17.2",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.3.4",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.32.1"
  }
}
